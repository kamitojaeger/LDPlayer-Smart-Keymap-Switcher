{
  "name": "游戏名称",
  "package": "com.example.game",
  "description": "",
  "author": "",
  "version": "1.0",
  "schema_version": 2,

  "resolution": {
    "width": 1920,
    "height": 1080
  },

  "detection": {
    "method": "template_matching",
    "interval_ms": 500,
    "threshold": 0.75,
    "feature_mask": {
      "enabled": true,
      "dark_percentile": 22,
      "bright_percentile": 82
    }
  },

  "regions": {
    "default": {
      "method": "bottom_right",
      "search_expand": 16,
      "margin_bottom": 40,
      "margin_right": 40,
      "slack": 20
    }
  },

  "states": [
    {
      "id": "state_a",
      "name": "状态A",
      "description": "",
      "keymap": "keymaps/state_a.kmp",
      "mouse_drag_key": null,
      "priority": 0,
      "templates": [
        { "path": "templates/state_a.png", "region": "default" }
      ],
      "match_logic": "any"
    },
    {
      "id": "state_b",
      "name": "状态B",
      "description": "",
      "keymap": "keymaps/state_b.kmp",
      "mouse_drag_key": null,
      "priority": 0,
      "templates": [
        { "path": "templates/state_b.png", "region": "default" }
      ],
      "match_logic": "any"
    }
  ],

  "none_state": {
    "keymap": "keymaps/state_a.kmp",
    "mouse_drag_key": null
  }
}
