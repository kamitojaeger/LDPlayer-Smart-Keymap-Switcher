# Auto-detect text files, convert to LF on commit
* text=auto

# Python
*.py text eol=lf

# C++ / C
*.cpp text eol=crlf
*.h text eol=crlf
*.asm text eol=crlf

# Build scripts
*.bat text eol=crlf
*.ps1 text eol=crlf
*.cmd text eol=crlf

# Config / data
*.json text eol=lf
*.txt text eol=lf
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Binary files
*.dll binary
*.exe binary
*.png binary
*.kmp binary
